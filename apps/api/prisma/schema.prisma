generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  freelancer
  company
}

enum JobStatus {
  DRAFT
  OPEN
  ASSIGNED
  ESCROW_FUNDED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

enum JobApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum JobInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  PARTIALLY_RELEASED
  FULLY_RELEASED
  REFUNDED
  HELD
}

enum EscrowReleaseTrigger {
  CLIENT_APPROVAL
  AUTO_RELEASE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  RELEASED
  DISPUTED
  REVISION_REQUESTED
}

enum SubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum GLMDecisionType {
  BRIEF_VALIDATION
  MILESTONE_SCORING
  DISPUTE_ANALYSIS
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum StatementStatus {
  GENERATED
  VERIFIED
  REVOKED
}

model User {
  id               String                 @id @default(cuid())
  email            String                 @unique
  passwordHash     String
  name             String
  role             Role
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  freelancerProfile FreelancerProfile?
  companyProfile   CompanyProfile?
  companyJobs      Job[]                  @relation("JobCompany")
  freelancerJobs   Job[]                  @relation("JobFreelancer")
  jobApplications  JobApplication[]       @relation("JobApplicationFreelancer")
  raisedDisputes   Dispute[]              @relation("DisputeRaisedBy")
  notifications    Notification[]         @relation("NotificationRecipient")
  sentMessages     ConversationMessage[]  @relation("ConversationMessageSender")
  conversationParticipants ConversationParticipant[]
  createdThreads   ConversationThread[]   @relation("ConversationThreadCreator")
  activityLogs     ActivityLog[]          @relation("ActivityActor")
  incomeStatements IncomeStatement[]      @relation("IncomeStatementFreelancer")
  sentInvitations  JobInvitation[]        @relation("JobInvitationCompany")
  receivedInvitations JobInvitation[]     @relation("JobInvitationFreelancer")
}

model FreelancerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String
  portfolioUrl  String?
  skills        Json?
  hourlyRate    Decimal? @db.Decimal(10, 2)
  ratingAverage Decimal? @db.Decimal(4, 2)
  headline      String?
  bio           String?
  experienceYears Int?
  pastProjects  Json?
  resumeFileName String?
  resumeStorageKey String?
  resumeUploadedAt DateTime?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id          String @id @default(cuid())
  userId      String @unique
  companyName String
  website     String?
  industry    String?
  about       String?
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id           String          @id @default(cuid())
  companyId    String
  freelancerId String?
  title        String
  description  String?         @db.Text
  budget       Decimal         @db.Decimal(12, 2)
  milestoneCount Int           @default(1)
  status       JobStatus       @default(DRAFT)
  publishedAt  DateTime?
  assignedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  company      User            @relation("JobCompany", fields: [companyId], references: [id], onDelete: Cascade)
  freelancer   User?           @relation("JobFreelancer", fields: [freelancerId], references: [id], onDelete: SetNull)
  brief        JobBrief?
  escrow       Escrow?
  milestones   Milestone[]
  applications JobApplication[]
  invitations  JobInvitation[]
  conversations ConversationThread[]
  glmDecisions GLMDecision[]

  @@index([companyId])
  @@index([freelancerId])
  @@index([status])
}

model JobInvitation {
  id           String              @id @default(cuid())
  jobId         String
  companyId     String
  freelancerId  String
  note          String?
  status        JobInvitationStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  respondedAt   DateTime?
  job           Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company       User                @relation("JobInvitationCompany", fields: [companyId], references: [id], onDelete: Cascade)
  freelancer    User                @relation("JobInvitationFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([freelancerId, status])
  @@index([jobId, status])
}

model ConversationThread {
  id            String                     @id @default(cuid())
  jobId         String?
  createdById   String
  subject       String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  job           Job?                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy     User                       @relation("ConversationThreadCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants  ConversationParticipant[]
  messages      ConversationMessage[]

  @@index([jobId])
  @@index([updatedAt])
}

model ConversationParticipant {
  id          String             @id @default(cuid())
  threadId    String
  userId      String
  lastReadAt  DateTime?
  createdAt   DateTime           @default(now())
  thread      ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId])
}

model ConversationMessage {
  id          String             @id @default(cuid())
  threadId    String
  senderId    String
  body        String
  createdAt   DateTime           @default(now())
  thread      ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User               @relation("ConversationMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model JobBrief {
  id                     String   @id @default(cuid())
  jobId                  String   @unique
  overview               String?
  scope                  Json?
  deliverables           Json?
  requirements           Json?
  acceptanceCriteria     Json?
  timeline               Json?
  briefData              Json?
  glmBriefScore          Int?
  glmValidationSummary   String?
  glmGaps                Json?
  glmClarifyingQuestions Json?
  lastValidatedAt        DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  job                    Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id           String               @id @default(cuid())
  jobId        String
  freelancerId String
  status       JobApplicationStatus @default(PENDING)
  coverNote    String?
  appliedAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  job          Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancer   User                 @relation("JobApplicationFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerId])
  @@index([freelancerId])
  @@index([status])
}

model Escrow {
  id                String          @id @default(cuid())
  jobId             String          @unique
  status            EscrowStatus    @default(UNFUNDED)
  fundedAmount      Decimal         @default(0) @db.Decimal(12, 2)
  releasedAmount    Decimal         @default(0) @db.Decimal(12, 2)
  provider          String?
  providerReference String?
  fundedAt          DateTime?
  releasedAt        DateTime?
  heldAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  job               Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  releases          EscrowRelease[]

  @@index([status])
}

model EscrowRelease {
  id         String               @id @default(cuid())
  escrowId   String
  milestoneId String
  amount     Decimal              @db.Decimal(12, 2)
  trigger    EscrowReleaseTrigger
  releasedAt DateTime             @default(now())
  escrow     Escrow               @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  milestone  Milestone            @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([escrowId, milestoneId])
  @@index([milestoneId])
}

model Milestone {
  id             String                    @id @default(cuid())
  jobId          String
  sequence       Int
  title          String
  description    String?
  amount         Decimal                   @db.Decimal(12, 2)
  status         MilestoneStatus           @default(PENDING)
  dueAt          DateTime?
  submittedAt    DateTime?
  reviewDueAt    DateTime?
  approvedAt     DateTime?
  releasedAt     DateTime?
  revisionRequestedAt DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  job            Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions    Submission[]
  escrowReleases EscrowRelease[]
  lineItems      IncomeStatementLineItem[]
  glmDecisions   GLMDecision[]

  @@unique([jobId, sequence])
  @@index([status])
}

model Submission {
  id            String           @id @default(cuid())
  milestoneId    String
  revision      Int              @default(1)
  status        SubmissionStatus @default(PENDING_REVIEW)
  notes         String?
  reviewDecision String?
  rejectionReason String?
  fileName      String?
  fileFormat    String?
  fileSizeBytes Int?
  fileHash      String?
  wordCount     Int?
  dimensions    String?
  activityLog   Json?
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  milestone     Milestone        @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  dispute       Dispute?
  glmDecisions  GLMDecision[]

  @@unique([milestoneId, revision])
  @@index([status])
}

model Dispute {
  id                String         @id @default(cuid())
  submissionId      String         @unique
  raisedById        String
  status            DisputeStatus  @default(OPEN)
  rejectionReason   String
  resolutionType    String?
  resolutionSummary String?
  openedAt          DateTime       @default(now())
  resolvedAt        DateTime?
  submission        Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  raisedBy          User           @relation("DisputeRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)
  glmDecisions      GLMDecision[]

  @@index([raisedById])
  @@index([status])
}

model GLMDecision {
  id                String          @id @default(cuid())
  jobId             String
  milestoneId       String?
  submissionId      String?
  disputeId         String?
  decisionType      GLMDecisionType
  overallScore      Int?
  passFail          String?
  recommendation    String?
  requirementScores Json?
  badFaithFlags     Json?
  reasoning         String?
  rawResponse       Json?
  createdAt         DateTime        @default(now())
  job               Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  milestone         Milestone?      @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  submission        Submission?     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  dispute           Dispute?        @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([decisionType])
}

model Notification {
  id             String                     @id @default(cuid())
  recipientId    String
  type           String
  title          String
  message        String?
  payload        Json?
  isRead         Boolean                    @default(false)
  deliveryStatus NotificationDeliveryStatus @default(PENDING)
  readAt         DateTime?
  sentAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  recipient      User                       @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([deliveryStatus])
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  entityType String
  entityId   String
  eventType  String
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
}

model IncomeStatement {
  id              String                    @id @default(cuid())
  freelancerId    String
  periodStart     DateTime
  periodEnd       DateTime
  totalEarned     Decimal                   @db.Decimal(12, 2)
  totalJobs       Int
  totalMilestones Int
  avgMonthlyIncome Decimal                  @db.Decimal(12, 2)
  currency        String                    @default("MYR")
  generatedAt     DateTime                  @default(now())
  pdfStorageKey   String?
  verifyToken     String                    @unique
  glmNarrative    String?
  status          StatementStatus           @default(GENERATED)
  freelancer      User                      @relation("IncomeStatementFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)
  lineItems       IncomeStatementLineItem[]

  @@index([freelancerId])
  @@index([status])
}

model IncomeStatementLineItem {
  id                String          @id @default(cuid())
  incomeStatementId String
  milestoneId       String
  jobTitle          String
  companyName       String
  amount            Decimal         @db.Decimal(12, 2)
  releasedAt        DateTime
  category          String?
  incomeStatement   IncomeStatement @relation(fields: [incomeStatementId], references: [id], onDelete: Cascade)
  milestone         Milestone       @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([incomeStatementId, milestoneId])
  @@index([milestoneId])
}
